# Supabase connection — copy to .env.local and fill in real values.
# .env.local is gitignored; .env.example is checked in (no secrets here).

# Used by Vite (the React app). Must be prefixed VITE_ to be exposed to client code.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Used by the Node scripts in scripts/. The publishable key has the same scope as
# the anon JWT — use either, but keep them in sync with the Vite values above.
# Run scripts with:  node --env-file=.env.local scripts/<name>.mjs
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── MCP serverless function (api/mcp.ts) ─────────────────────────────────────

# Server-only key for the MCP serverless function. NEVER prefix with VITE_.
# Use the service role key from Supabase → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public base URL used to construct the MCP endpoint shown in the parent UI.
# In dev this can be http://localhost:3000.
# Node scripts read the bare var; Vite reads the VITE_ mirror (same pattern as SUPABASE_URL above).
PUBLIC_BASE_URL=https://your-vercel-domain.vercel.app
VITE_PUBLIC_BASE_URL=https://your-vercel-domain.vercel.app

# Optional comma-separated origins appended to the default MCP allow-list.
# Default list: https://claude.ai, https://*.claude.ai, https://chatgpt.com, https://cursor.so
MCP_ALLOWED_ORIGINS_EXTRA=
